<Defaults>
    <Button class="TimerButtons" height="75" audioVolume="0" width="150" color="#ccccccff" fontSize="25" textColor="#000000FF" fontStyle="Bold" active="true"/>
</Defaults>

<Panel id="Clock"
    active="true"
    width="730"
    height="110"
    position="125 165 -155"
    rotation="0 55 -90"
    color="#222222ff">
    <HorizontalLayout id="SetupPanel" childForceExpandWidth="true" childForceExpandHeight="true" childAlignment="MiddleCenter" spacing="4" padding="30 15 0 0">

        <Panel color="#aaaaff00" childForceExpandWidth="false" childForceExpandHeight="true">
          <VerticalLayout childForceExpandHeight="false" childForceExpandWidth="true" childAlignment="MiddleCenter" color="#FFaaff00">
            <Button height="65%" id="LengthButton" audioVolume="0" minHeight="40" fontSize="25" color="#ccccccff" fontStyle="Bold" active="true" onClick="lengthButton">75 Min</Button>
            <HorizontalLayout height="40%" childForceExpandWidth="true" childForceExpandHeight="false" childAlignment="MiddleCenter" >
              <Button id="MinusLengthButton" audioVolume="0" minHeight="35" fontSize="20" class="TimerButtons" onClick="minusLengthButton">-</Button>
              <Button id="PlusLengthButton" audioVolume="0" minHeight="35" fontSize="20" class="TimerButtons" onClick="plusLengthButton">+</Button>
            </HorizontalLayout>
          </VerticalLayout>
        </Panel>

      <Panel color="#aaaaff00">
        <Button id="RandomButton" class="TimerButtons" onClick="randomButton">Fixed</Button>
      </Panel>
      <Panel color="#ffaaaa00">
        <Button id="HiddenButton" class="TimerButtons" onClick="hiddenButton">Visible</Button>
      </Panel>
      <Panel color="#ffaaaa00">
        <VerticalLayout childForceExpandHeight="false" childForceExpandWidth="true" childAlignment="MiddleCenter" color="#FFaaff00">
          <Button id="StartButton" class="TimerButtons"  minHeight="50" maxHeight="80" onClick="startButton">Start</Button>
          <Button id="AutoStartButton" class="TimerButtons" minHeight="33" maxHeight="50" onClick="autoStartButton">Auto</Button>
        </VerticalLayout>
      </Panel>

    </HorizontalLayout>

    <HorizontalLayout id="StartedClockPanel" color="#222222ff" childForceExpandWidth="true" childForceExpandHeight="true" childAlignment="MiddleCenter" onClick="startButton" spacing="0" active="false">
      <Text id="TimerText" height="75" width="150" color="#FF3333ff" audioVolume="0" fontSize="95" fontStyle="Bold" onClick="pauseButton">Start</Text>
    </HorizontalLayout>
</Panel>

<Panel id="ScoringModePanel"
    active="true"
    width="350"
    height="110"
    position="125 -370 -155"
    rotation="0 55 -90"
    color="#222222ff">
    <HorizontalLayout childForceExpandWidth="true" childForceExpandHeight="true" childAlignment="MiddleCenter" spacing="4" padding="30 20 0 0">
      <Panel color="#ffaaaa00">
        <Button id="ScoringModeSplitBtn" class="TimerButtons" onClick="setScoringModeSplit">Split</Button>
      </Panel>
      <Panel color="#ffaaaa00">
        <Button id="ScoringModeClassicBtn" class="TimerButtons" onClick="setScoringModeClassic">Classic</Button>
      </Panel>
    </HorizontalLayout>
</Panel>

<!-- LEFT PLAYER - Score only -->
<Panel id="LeftPlayer"
    active="true"
    width="300"
    height="215"
    position="0 1145 0"
    rotation="0 45 -90"
    color="#222222ff">

    <Button id="RegisterLeft" class="TimerButtons"
            width="200" height="130" fontSize="40"
            onClick="registerPlayerFromGui">Register</Button>

    <Panel id="LeftPointPanel" color="#222222FF" active="false">

      <HorizontalLayout
        childForceExpandWidth="true" childForceExpandHeight="true"
        childAlignment="MiddleCenter" spacing="0" padding="5 5 5 5">

        <Text id="LeftPointText"
              height="75"
              minWidth="40"
              preferredWidth="220"
              maxWidth="500"
              color="#000000ff"
              fontSize="130"
              fontStyle="Bold"
              alignment="MiddleCenter">0</Text>
      </HorizontalLayout>

      <Button id="LeftModeToggle" class="TimerButtons"
              rectAlignment="UpperCenter" offsetXY="0 -5"
              width="120" height="48"
              fontSize="22" onClick="togglePointMode" active="false">Ship</Button>

      <Text id="LeftShipPointsText"
            rectAlignment="LowerCenter" offsetXY="-42 2"
            width="70" height="30"
            color="#000000ff" fontSize="24" fontStyle="Bold"
            alignment="MiddleCenter" active="false">S:0</Text>
      <Text id="LeftScenPointsText"
            rectAlignment="LowerCenter" offsetXY="42 2"
            width="70" height="30"
            color="#000000ff" fontSize="24" fontStyle="Bold"
            alignment="MiddleCenter" active="false">O:0</Text>
    </Panel>
</Panel>

<!-- LEFT PLAYER - Controls (above score) -->
<Panel id="LeftControls"
    active="true"
    width="270"
    height="120"
    position="125 1141 -155"
    rotation="0 55 -90"
    color="#333333ff">

    <Panel id="LeftControlsInner" color="#333333FF" active="false">
      <HorizontalLayout childForceExpandWidth="true" childForceExpandHeight="true"
                         childAlignment="MiddleCenter" spacing="4" padding="16 10 8 8">
        <VerticalLayout childForceExpandWidth="true" childForceExpandHeight="true"
                        childAlignment="MiddleCenter" spacing="2">
          <Button id="LeftModeShipBtn" class="TimerButtons"
                  minHeight="30" fontSize="20" onClick="setPointModeShip">Ship</Button>
          <Button id="LeftModeObjBtn" class="TimerButtons"
                  minHeight="30" fontSize="20" onClick="setPointModeObj">Obj</Button>
        </VerticalLayout>
        <VerticalLayout childForceExpandWidth="true" childForceExpandHeight="true"
                        childAlignment="MiddleCenter" spacing="2">
          <Button id="LeftPointPlus" class="TimerButtons"
                  minHeight="30" fontSize="20" onClick="addPoint">+1</Button>
          <Button id="LeftPointMinus" class="TimerButtons"
                  minHeight="30" fontSize="20" onClick="addPoint">-1</Button>
        </VerticalLayout>
        <VerticalLayout childForceExpandWidth="true" childForceExpandHeight="true"
                        childAlignment="MiddleCenter" spacing="2">
          <Button id="LeftPointPlus2" class="TimerButtons"
                  minHeight="30" fontSize="20" onClick="addPoint">+2</Button>
          <Button id="LeftPointPlus4" class="TimerButtons"
                  minHeight="30" fontSize="20" onClick="addPoint">+4</Button>
        </VerticalLayout>
      </HorizontalLayout>
    </Panel>
</Panel>


